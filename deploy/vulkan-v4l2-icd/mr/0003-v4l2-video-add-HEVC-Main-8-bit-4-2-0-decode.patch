+/* set_codec_controls: generalized per-request codec control setter.
+ * H264: delegates unchanged to set_h264_controls.
+ * H265: builds control array from v4l2vk_hevc_frame_params:
+ *   SPS, PPS, SCALING (has_scaling), DECODE_PARAMS, SLICE_PARAMS (slice_count),
+ *   EXT_SPS_ST_RPS (st_rps_count), EXT_SPS_LT_RPS (lt_rps_count). */
+int
+v4l2vk_v4l2_set_codec_controls(struct v4l2vk_v4l2_context *ctx,
+                               int request_fd, int codec,
+                               const void *params)
+{
+   if (codec == V4L2VK_CODEC_H265) {
+      const struct v4l2vk_hevc_frame_params *hp =
+         (const struct v4l2vk_hevc_frame_params *)params;
+
+      /* 7 possible controls: SPS PPS SCALING DECODE_PARAMS SLICE_PARAMS
+       * EXT_SPS_ST_RPS EXT_SPS_LT_RPS */
+      struct v4l2_ext_control ctrls[7];
+      uint32_t n = 0;
+      memset(ctrls, 0, sizeof(ctrls));
+
+      if (ctx->has_ctrl_hevc_sps) {
+         ctrls[n].id   = V4L2_CID_STATELESS_HEVC_SPS;
+         ctrls[n].size = sizeof(hp->sps);
+         ctrls[n].ptr  = (void *)&hp->sps;
+         n++;
+      }
+      if (ctx->has_ctrl_hevc_pps) {
+         ctrls[n].id   = V4L2_CID_STATELESS_HEVC_PPS;
+         ctrls[n].size = sizeof(hp->pps);
+         ctrls[n].ptr  = (void *)&hp->pps;
+         n++;
+      }
+      if (ctx->has_ctrl_hevc_scaling && hp->has_scaling) {
+         ctrls[n].id   = V4L2_CID_STATELESS_HEVC_SCALING_MATRIX;
+         ctrls[n].size = sizeof(hp->scaling);
+         ctrls[n].ptr  = (void *)&hp->scaling;
+         n++;
+      }
+      if (ctx->has_ctrl_hevc_decode_params) {
+         ctrls[n].id   = V4L2_CID_STATELESS_HEVC_DECODE_PARAMS;
+         ctrls[n].size = sizeof(hp->decode_params);
+         ctrls[n].ptr  = (void *)&hp->decode_params;
+         n++;
+      }
+      if (ctx->has_ctrl_hevc_slice_params && hp->slice_count > 0) {
+         ctrls[n].id   = V4L2_CID_STATELESS_HEVC_SLICE_PARAMS;
+         ctrls[n].size = sizeof(struct v4l2_ctrl_hevc_slice_params)
+                         * hp->slice_count;
+         ctrls[n].ptr  = (void *)hp->slice_params;
+         n++;
+      }
+      if (ctx->has_ctrl_hevc_ext_sps_st_rps && hp->st_rps_count > 0) {
+         ctrls[n].id   = V4L2_CID_STATELESS_HEVC_EXT_SPS_ST_RPS;
+         ctrls[n].size = sizeof(struct v4l2_ctrl_hevc_ext_sps_st_rps)
+                         * hp->st_rps_count;
+         ctrls[n].ptr  = (void *)hp->st_rps;
+         n++;
+      }
+      if (ctx->has_ctrl_hevc_ext_sps_lt_rps && hp->lt_rps_count > 0) {
+         ctrls[n].id   = V4L2_CID_STATELESS_HEVC_EXT_SPS_LT_RPS;
+         ctrls[n].size = sizeof(struct v4l2_ctrl_hevc_ext_sps_lt_rps)
+                         * hp->lt_rps_count;
+         ctrls[n].ptr  = (void *)hp->lt_rps;
+         n++;
+      }
+
+      fprintf(stderr,
+              "[V4L2VK][V4L2] HEVC S_EXT_CTRLS: video_fd=%d request_fd=%d count=%u\n",
+              ctx->video_fd, request_fd, n);
+
+      struct v4l2_ext_controls ext_ctrls;
+      memset(&ext_ctrls, 0, sizeof(ext_ctrls));
+      ext_ctrls.which      = V4L2_CTRL_WHICH_REQUEST_VAL;
+      ext_ctrls.request_fd = request_fd;
+      ext_ctrls.count      = n;
+      ext_ctrls.controls   = ctrls;
+
+      if (xioctl(ctx->video_fd, VIDIOC_S_EXT_CTRLS, &ext_ctrls) < 0) {
+         int err = errno;
+         fprintf(stderr,
+                 "[V4L2VK][V4L2] HEVC S_EXT_CTRLS FAILED: %s (errno=%d) error_idx=%u\n",
+                 strerror(err), err, ext_ctrls.error_idx);
+         for (uint32_t i = 0; i < n; i++) {
+            struct v4l2_ext_controls single;
+            memset(&single, 0, sizeof(single));
+            single.which      = V4L2_CTRL_WHICH_REQUEST_VAL;
+            single.request_fd = request_fd;
+            single.count      = 1;
+            single.controls   = &ctrls[i];
+            int rc = xioctl(ctx->video_fd, VIDIOC_S_EXT_CTRLS, &single);
+            fprintf(stderr,
+                    "[V4L2VK][V4L2]   ctrl 0x%08x (%s) size=%u: %s\n",
+                    ctrls[i].id, v4l2vk_ctrl_name(ctrls[i].id),
+                    ctrls[i].size, rc < 0 ? strerror(errno) : "OK");
+         }
+         return -err;
+      }
+      fprintf(stderr, "[V4L2VK][V4L2] HEVC S_EXT_CTRLS: OK\n");
+      return 0;
+   }
+
+   /* H264 (default): delegate unchanged to existing function */
+   return v4l2vk_v4l2_set_h264_controls(
+      ctx, request_fd,
+      (const struct v4l2vk_h264_frame_params *)params);
+}
