+           "DECODE_PARAMS=%d SLICE_PARAMS=%d ST_RPS=%d LT_RPS=%d\n",
+           ctx->has_ctrl_hevc_sps, ctx->has_ctrl_hevc_pps,
+           ctx->has_ctrl_hevc_scaling, ctx->has_ctrl_hevc_decode_params,
