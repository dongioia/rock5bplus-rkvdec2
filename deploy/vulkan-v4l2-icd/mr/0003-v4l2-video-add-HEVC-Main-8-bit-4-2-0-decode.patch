+
+   /* Set OUTPUT pixelformat to V4L2_PIX_FMT_HEVC_SLICE */
+   if (v4l2vk_v4l2_set_output_format_codec(sess->v4l2_ctx, w, h,
+                                            V4L2VK_CODEC_H265) < 0) {
+      fprintf(stderr, "[V4L2VK][ERR] HEVC: OUTPUT format setup failed\n");
+      v4l2vk_v4l2_context_destroy(sess->v4l2_ctx);
+      sess->v4l2_ctx = NULL;
+      return -1;
+   }
+
+   /* Non-request SPS init — must precede CAPTURE setup so rkvdec configures the decoder */
+   if (sps) {
+      struct v4l2vk_hevc_frame_params init_params;
+      memset(&init_params, 0, sizeof(init_params));
+      v4l2vk_h265_translate_sps(sps, &init_params.sps);
+      if (v4l2vk_v4l2_set_init_paramset(sess->v4l2_ctx,
+                                         V4L2VK_CODEC_H265,
+                                         &init_params) < 0) {
+         fprintf(stderr,
+                 "[V4L2VK][ERR] HEVC: V4L2 non-request SPS set failed\n");
+         v4l2vk_v4l2_context_destroy(sess->v4l2_ctx);
+         sess->v4l2_ctx = NULL;
+         return -1;
+      }
+   }
+
+   if (v4l2vk_v4l2_set_capture_format(sess->v4l2_ctx, w, h, NULL, NULL) < 0) {
+      fprintf(stderr, "[V4L2VK][ERR] HEVC: V4L2 CAPTURE format setup failed\n");
+      v4l2vk_v4l2_context_destroy(sess->v4l2_ctx);
+      sess->v4l2_ctx = NULL;
+      return -1;
+   }
+
+   if (v4l2vk_v4l2_create_output_buffers(sess->v4l2_ctx, 4) < 0) {
+      fprintf(stderr, "[V4L2VK][ERR] HEVC: V4L2 OUTPUT buffer setup failed\n");
+      v4l2vk_v4l2_context_destroy(sess->v4l2_ctx);
+      sess->v4l2_ctx = NULL;
+      return -1;
+   }
+
+   if (v4l2vk_v4l2_create_capture_buffers(sess->v4l2_ctx, 17) < 0) {
+      fprintf(stderr,
+              "[V4L2VK][ERR] HEVC: V4L2 CAPTURE buffer setup failed\n");
+      v4l2vk_v4l2_context_destroy(sess->v4l2_ctx);
+      sess->v4l2_ctx = NULL;
+      return -1;
+   }
+
+   if (v4l2vk_v4l2_streamon(sess->v4l2_ctx) < 0) {
+      fprintf(stderr, "[V4L2VK][ERR] HEVC: V4L2 STREAMON failed\n");
+      v4l2vk_v4l2_context_destroy(sess->v4l2_ctx);
+      sess->v4l2_ctx = NULL;
+      return -1;
+   }
+
+   sess->coded_extent.width  = w;
+   sess->coded_extent.height = h;
+
+   fprintf(stderr,
+           "[V4L2VK] HEVC V4L2 session initialized: %ux%u, "
+           "%u output bufs, CAPTURE MMAP %u bufs\n",
+           w, h, sess->v4l2_ctx->output_buf_count,
+           sess->v4l2_ctx->capture_buf_count);
+
+   return 0;
+}
+
