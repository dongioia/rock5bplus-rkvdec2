 }
 
+/* set_output_format_codec: selects pixelformat from codec enum.
+ * H264 (0) -> H264_SLICE (same as set_output_format).
+ * H265 (1) -> HEVC_SLICE. */
+int
+v4l2vk_v4l2_set_output_format_codec(struct v4l2vk_v4l2_context *ctx,
+                                    uint32_t w, uint32_t h, int codec)
+{
+   uint32_t pixfmt = (codec == V4L2VK_CODEC_H265)
+                     ? V4L2_PIX_FMT_HEVC_SLICE
+                     : V4L2_PIX_FMT_H264_SLICE;
+
+   struct v4l2_format fmt;
+   memset(&fmt, 0, sizeof(fmt));
+   fmt.type = V4L2_BUF_TYPE_VIDEO_OUTPUT_MPLANE;
+   fmt.fmt.pix_mp.width = w;
+   fmt.fmt.pix_mp.height = h;
+   fmt.fmt.pix_mp.pixelformat = pixfmt;
+   fmt.fmt.pix_mp.num_planes = 1;
+   fmt.fmt.pix_mp.plane_fmt[0].sizeimage = 1024 * 1024;
+
+   if (xioctl(ctx->video_fd, VIDIOC_S_FMT, &fmt) < 0) {
+      V4L2VK_LOGI_V4L2("[V4L2VK][V4L2] S_FMT OUTPUT (codec=%d) failed: %s\n",
+                       codec, strerror(errno));
+      return -errno;
+   }
+   ctx->output_stride = fmt.fmt.pix_mp.plane_fmt[0].bytesperline;
+   V4L2VK_LOGI_V4L2("[V4L2VK][V4L2] OUTPUT fmt (codec=%d): %ux%u\n",
+                    codec, fmt.fmt.pix_mp.width, fmt.fmt.pix_mp.height);
+   return 0;
+}
+
 int
 v4l2vk_v4l2_set_capture_format(struct v4l2vk_v4l2_context *ctx, uint32_t w,
                                uint32_t h, uint32_t *stride,
@@ -252,6 +302,46 @@ v4l2vk_v4l2_set_init_sps(struct v4l2vk_v4l2_context *ctx,
    return 0;
 }
 
+/* set_init_paramset: generalized non-request init control.
+ * H264: sets V4L2_CID_STATELESS_H264_SPS (= set_init_sps behavior).
+ * H265: sets V4L2_CID_STATELESS_HEVC_SPS (single non-request
+ *   ctrl between S_FMT(OUTPUT,HEVC_SLICE) and CAPTURE setup). */
+int
+v4l2vk_v4l2_set_init_paramset(struct v4l2vk_v4l2_context *ctx,
+                              int codec, const void *params)
+{
+   struct v4l2_ext_control ctrl;
+   memset(&ctrl, 0, sizeof(ctrl));
+
+   if (codec == V4L2VK_CODEC_H265) {
+      const struct v4l2vk_hevc_frame_params *hp =
+         (const struct v4l2vk_hevc_frame_params *)params;
+      ctrl.id   = V4L2_CID_STATELESS_HEVC_SPS;
+      ctrl.size = sizeof(hp->sps);
+      ctrl.ptr  = (void *)&hp->sps;
+   } else {
+      const struct v4l2vk_h264_frame_params *hp =
+         (const struct v4l2vk_h264_frame_params *)params;
+      ctrl.id   = V4L2_CID_STATELESS_H264_SPS;
+      ctrl.size = sizeof(hp->sps);
+      ctrl.ptr  = (void *)&hp->sps;
+   }
+
+   struct v4l2_ext_controls ext;
+   memset(&ext, 0, sizeof(ext));
+   ext.which    = V4L2_CTRL_WHICH_CUR_VAL;
+   ext.count    = 1;
+   ext.controls = &ctrl;
+
+   if (xioctl(ctx->video_fd, VIDIOC_S_EXT_CTRLS, &ext) < 0) {
+      V4L2VK_LOGI_V4L2("[V4L2VK][V4L2] init_paramset (codec=%d) failed: %s\n",
+                       codec, strerror(errno));
+      return -errno;
+   }
+   V4L2VK_LOGI_V4L2("[V4L2VK][V4L2] init_paramset (codec=%d) OK\n", codec);
+   return 0;
+}
+
 /* --- Streaming --- */
 
