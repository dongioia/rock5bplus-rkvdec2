From 86e444d5a74de1869f32279c7053e92425427d70 Mon Sep 17 00:00:00 2001
From: Saverio Pavone <pavone.lawyer@gmail.com>
Date: Thu, 25 Jun 2026 16:17:57 +0000
Subject: [PATCH 1/3] v4l2-video: set the H.264 SPS non-request at session init

The decoder set the SPS control only per-request. rkvdec's stateless H.264
path wants the SPS once as a plain (non-request) control, after S_FMT(OUTPUT)
and before the CAPTURE format and buffers are set up; without it the hardware
stays unconfigured and writes a blank frame, even though the per-request
controls are byte-identical to the in-tree v4l2slh264dec decoding the same
clip. Set the SPS non-request at init, and read the driver's native CAPTURE
format rather than forcing one.

Found by diffing the two drivers' VIDIOC_S_EXT_CTRLS traces on an RK3588;
with the fix the output is byte-exact against ffmpeg on baseline, High with
B-frames, multi-slice and cropped streams.

Signed-off-by: Saverio Pavone <pavone.lawyer@gmail.com>
Assisted-by: Claude:claude-opus-4-8
---
 src/vulkan-v4l2/v4l2vk_v4l2.c      | 33 ++++++++++++++++++++++++--
 src/vulkan-v4l2/v4l2vk_v4l2.h      |  3 +++
 src/vulkan-v4l2/v4l2vk_v4l2_h264.c | 10 ++++++++
 src/vulkan-v4l2/v4l2vk_v4l2_h264.h |  5 ++++
 src/vulkan-v4l2/v4l2vk_vk_device.c |  2 +-
 src/vulkan-v4l2/v4l2vk_vk_video.c  | 38 ++++++++++++++++++++++++++----
 src/vulkan-v4l2/v4l2vk_vk_video.h  |  4 +++-
 7 files changed, 86 insertions(+), 9 deletions(-)

diff --git a/src/vulkan-v4l2/v4l2vk_v4l2.c b/src/vulkan-v4l2/v4l2vk_v4l2.c
index 2dc80b1..b3ba528 100644
--- a/src/vulkan-v4l2/v4l2vk_v4l2.c
+++ b/src/vulkan-v4l2/v4l2vk_v4l2.c
@@ -202,8 +202,9 @@ v4l2vk_v4l2_set_capture_format(struct v4l2vk_v4l2_context *ctx, uint32_t w,
    fmt.fmt.pix_mp.pixelformat = V4L2_PIX_FMT_NV12;
    fmt.fmt.pix_mp.num_planes = 1;
 
-   if (xioctl(ctx->video_fd, VIDIOC_S_FMT, &fmt) < 0) {
-      V4L2VK_LOGI_V4L2("[V4L2VK][V4L2] S_FMT CAPTURE failed: %s\n",
+   /* read the driver native CAPTURE format (G_FMT), do not force */
+   if (xioctl(ctx->video_fd, VIDIOC_G_FMT, &fmt) < 0) {
+      V4L2VK_LOGI_V4L2("[V4L2VK][V4L2] G_FMT CAPTURE failed: %s\n",
                        strerror(errno));
       return -errno;
    }
@@ -223,6 +224,34 @@ v4l2vk_v4l2_set_capture_format(struct v4l2vk_v4l2_context *ctx, uint32_t w,
    return 0;
 }
 
+/* set SPS NON-request at init so rkvdec configures its decoder and
+ * computes the native CAPTURE layout (golden v4l2slh264dec does this before
+ * CAPTURE setup). Without it the decoder is unconfigured -> blank decode. */
+int
+v4l2vk_v4l2_set_init_sps(struct v4l2vk_v4l2_context *ctx,
+                         const struct v4l2vk_h264_frame_params *params)
+{
+   struct v4l2_ext_control ctrl;
+   memset(&ctrl, 0, sizeof(ctrl));
+   ctrl.id = V4L2_CID_STATELESS_H264_SPS;
+   ctrl.size = sizeof(params->sps);
+   ctrl.ptr = (void *)&params->sps;
+
+   struct v4l2_ext_controls ext;
+   memset(&ext, 0, sizeof(ext));
+   ext.which = V4L2_CTRL_WHICH_CUR_VAL;
+   ext.count = 1;
+   ext.controls = &ctrl;
+
+   if (xioctl(ctx->video_fd, VIDIOC_S_EXT_CTRLS, &ext) < 0) {
+      V4L2VK_LOGI_V4L2("[V4L2VK][V4L2] init SPS S_EXT_CTRLS failed: %s\n",
+                       strerror(errno));
+      return -errno;
+   }
+   V4L2VK_LOGI_V4L2("[V4L2VK][V4L2] init SPS set (non-request) OK\n");
+   return 0;
+}
+
 /* --- Streaming --- */
 
 int
diff --git a/src/vulkan-v4l2/v4l2vk_v4l2.h b/src/vulkan-v4l2/v4l2vk_v4l2.h
index 0c558cd..0cdf580 100644
--- a/src/vulkan-v4l2/v4l2vk_v4l2.h
+++ b/src/vulkan-v4l2/v4l2vk_v4l2.h
@@ -82,6 +82,9 @@ int v4l2vk_v4l2_alloc_request(struct v4l2vk_v4l2_context *ctx, int *request_fd);
 int
 v4l2vk_v4l2_set_h264_controls(struct v4l2vk_v4l2_context *ctx, int request_fd,
                               const struct v4l2vk_h264_frame_params *params);
+
+int v4l2vk_v4l2_set_init_sps(struct v4l2vk_v4l2_context *ctx,
+                            const struct v4l2vk_h264_frame_params *params);
 int v4l2vk_v4l2_queue_output(struct v4l2vk_v4l2_context *ctx, uint32_t buf_idx,
                              int request_fd, const void *bitstream, size_t size,
                              uint64_t timestamp);
diff --git a/src/vulkan-v4l2/v4l2vk_v4l2_h264.c b/src/vulkan-v4l2/v4l2vk_v4l2_h264.c
index 3d59bc0..0fe4eb9 100644
--- a/src/vulkan-v4l2/v4l2vk_v4l2_h264.c
+++ b/src/vulkan-v4l2/v4l2vk_v4l2_h264.c
@@ -489,6 +489,16 @@ v4l2vk_h264_translate_pps(const StdVideoH264PictureParameterSet *vk,
       out->flags |= V4L2_H264_PPS_FLAG_SCALING_MATRIX_PRESENT;
 }
 
+/* --- public SPS+PPS translate wrapper (init non-request set) --- */
+void
+v4l2vk_h264_translate_sps_pps(const StdVideoH264SequenceParameterSet *vk_sps,
+                             const StdVideoH264PictureParameterSet *vk_pps,
+                             struct v4l2vk_h264_frame_params *out)
+{
+   v4l2vk_h264_translate_sps(vk_sps, &out->sps);
+   v4l2vk_h264_translate_pps(vk_pps, &out->pps);
+}
+
 /* --- Scaling matrix translation --- */
 static void
 v4l2vk_h264_translate_scaling(const StdVideoH264ScalingLists *vk,
diff --git a/src/vulkan-v4l2/v4l2vk_v4l2_h264.h b/src/vulkan-v4l2/v4l2vk_v4l2_h264.h
index f09499f..5076673 100644
--- a/src/vulkan-v4l2/v4l2vk_v4l2_h264.h
+++ b/src/vulkan-v4l2/v4l2vk_v4l2_h264.h
@@ -27,6 +27,11 @@ struct v4l2vk_h264_frame_params {
    bool has_scaling;
 };
 
+void v4l2vk_h264_translate_sps_pps(
+   const StdVideoH264SequenceParameterSet *vk_sps,
+   const StdVideoH264PictureParameterSet *vk_pps,
+   struct v4l2vk_h264_frame_params *out);
+
 int v4l2vk_h264_translate_params(const StdVideoH264SequenceParameterSet *vk_sps,
                                  const StdVideoH264PictureParameterSet *vk_pps,
                                  const StdVideoDecodeH264PictureInfo *vk_pic,
diff --git a/src/vulkan-v4l2/v4l2vk_vk_device.c b/src/vulkan-v4l2/v4l2vk_vk_device.c
index 2f65e44..90deae3 100644
--- a/src/vulkan-v4l2/v4l2vk_vk_device.c
+++ b/src/vulkan-v4l2/v4l2vk_vk_device.c
@@ -791,7 +791,7 @@ v4l2vk_QueueSubmit2(VkQueue queue, uint32_t submitCount,
                fprintf(stderr,
                        "[V4L2VK] Late V4L2 init from SPS: %ux%u\n",
                        sps_w, sps_h);
-               v4l2vk_video_session_init_v4l2(sess, dev, sps_w, sps_h);
+               v4l2vk_video_session_init_v4l2(sess, dev, sps_w, sps_h, &job->sps, &job->pps);
             }
 
             if (!sess->v4l2_ctx) {
diff --git a/src/vulkan-v4l2/v4l2vk_vk_video.c b/src/vulkan-v4l2/v4l2vk_vk_video.c
index e0cac83..7380f0d 100644
--- a/src/vulkan-v4l2/v4l2vk_vk_video.c
+++ b/src/vulkan-v4l2/v4l2vk_vk_video.c
@@ -4,6 +4,8 @@
  *     Sreerenj Balachandran <sreerenj@amazon.com>
  */
 #include "v4l2vk_vk_video.h"
+#include "v4l2vk_v4l2.h"
+#include "v4l2vk_v4l2_h264.h"
 #include <stdatomic.h>
 #include <stdio.h>
 #include <stdlib.h>
@@ -248,6 +250,11 @@ v4l2vk_CreateVideoSessionParametersKHR(
        h264_ci->pParametersAddInfo->pStdSPSs) {
       const StdVideoH264SequenceParameterSet *sps =
          &h264_ci->pParametersAddInfo->pStdSPSs[0];
+      const StdVideoH264PictureParameterSet *pps =
+         (h264_ci->pParametersAddInfo->stdPPSCount > 0 &&
+          h264_ci->pParametersAddInfo->pStdPPSs)
+            ? &h264_ci->pParametersAddInfo->pStdPPSs[0]
+            : NULL;
 
       uint32_t w = ((uint32_t)sps->pic_width_in_mbs_minus1 + 1) * 16;
       uint32_t h = ((uint32_t)sps->pic_height_in_map_units_minus1 + 1) * 16;
@@ -258,7 +265,7 @@ v4l2vk_CreateVideoSessionParametersKHR(
               "[V4L2VK] SPS resolution: %ux%u (session maxCodedExtent: %ux%u)\n",
               w, h, sess->coded_extent.width, sess->coded_extent.height);
 
-      if (v4l2vk_video_session_init_v4l2(sess, dev, w, h) < 0) {
+      if (v4l2vk_video_session_init_v4l2(sess, dev, w, h, sps, pps) < 0) {
          fprintf(stderr,
                  "[V4L2VK][ERR] V4L2 init failed for %ux%u\n", w, h);
          /* Non-fatal — QueueSubmit2 will try lazy init from job SPS */
@@ -480,7 +487,9 @@ v4l2vk_CmdDecodeVideoKHR(VkCommandBuffer cmd, const VkVideoDecodeInfoKHR *info)
 int
 v4l2vk_video_session_init_v4l2(v4l2vk_video_session *sess,
                                struct v4l2vk_vk_device *dev,
-                               uint32_t w, uint32_t h)
+                               uint32_t w, uint32_t h,
+                               const StdVideoH264SequenceParameterSet *sps,
+                               const StdVideoH264PictureParameterSet *pps)
 {
    if (sess->v4l2_ctx)
       return 0; /* Already initialized */
@@ -492,9 +501,28 @@ v4l2vk_video_session_init_v4l2(v4l2vk_video_session *sess,
       return -1;
    }
 
-   if (v4l2vk_v4l2_set_output_format(sess->v4l2_ctx, w, h) < 0 ||
-       v4l2vk_v4l2_set_capture_format(sess->v4l2_ctx, w, h, NULL, NULL) < 0) {
-      fprintf(stderr, "[V4L2VK][ERR] V4L2 format setup failed\n");
+   if (v4l2vk_v4l2_set_output_format(sess->v4l2_ctx, w, h) < 0) {
+      fprintf(stderr, "[V4L2VK][ERR] V4L2 OUTPUT format setup failed\n");
+      v4l2vk_v4l2_context_destroy(sess->v4l2_ctx);
+      sess->v4l2_ctx = NULL;
+      return -1;
+   }
+
+   /* set SPS non-request BEFORE CAPTURE format/buffers. */
+   if (sps && pps) {
+      struct v4l2vk_h264_frame_params init_params;
+      memset(&init_params, 0, sizeof(init_params));
+      v4l2vk_h264_translate_sps_pps(sps, pps, &init_params);
+      if (v4l2vk_v4l2_set_init_sps(sess->v4l2_ctx, &init_params) < 0) {
+         fprintf(stderr, "[V4L2VK][ERR] V4L2 init SPS set failed\n");
+         v4l2vk_v4l2_context_destroy(sess->v4l2_ctx);
+         sess->v4l2_ctx = NULL;
+         return -1;
+      }
+   }
+
+   if (v4l2vk_v4l2_set_capture_format(sess->v4l2_ctx, w, h, NULL, NULL) < 0) {
+      fprintf(stderr, "[V4L2VK][ERR] V4L2 CAPTURE format setup failed\n");
       v4l2vk_v4l2_context_destroy(sess->v4l2_ctx);
       sess->v4l2_ctx = NULL;
       return -1;
diff --git a/src/vulkan-v4l2/v4l2vk_vk_video.h b/src/vulkan-v4l2/v4l2vk_vk_video.h
index 34a1ef8..e60b1b2 100644
--- a/src/vulkan-v4l2/v4l2vk_vk_video.h
+++ b/src/vulkan-v4l2/v4l2vk_vk_video.h
@@ -29,7 +29,9 @@ typedef struct v4l2vk_video_params_t {
  * lazily from QueueSubmit2 if the SPS wasn't available at param creation. */
 int v4l2vk_video_session_init_v4l2(v4l2vk_video_session *sess,
                                    struct v4l2vk_vk_device *dev,
-                                   uint32_t w, uint32_t h);
+                                   uint32_t w, uint32_t h,
+                                   const StdVideoH264SequenceParameterSet *sps,
+                                   const StdVideoH264PictureParameterSet *pps);
 
 PFN_vkVoidFunction v4l2vk_GetVideoDeviceProcAddr(VkDevice dev,
                                                  const char *name);
