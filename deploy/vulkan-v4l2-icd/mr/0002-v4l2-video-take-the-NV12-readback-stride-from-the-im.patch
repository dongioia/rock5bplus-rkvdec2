From 921f1e5edb4a03f9b6132cef74f0f28f57a2e0d2 Mon Sep 17 00:00:00 2001
From: Saverio Pavone <pavone.lawyer@gmail.com>
Date: Thu, 25 Jun 2026 16:17:57 +0000
Subject: [PATCH 2/3] v4l2-video: take the NV12 readback stride from the image
 layout

The VkImage-to-system-memory readback computed the row stride as the width
rounded up to 256, while the rest of the path uses the width rounded up to 16
(the V4L2 bytesperline the kernel reports). Those agree only when the width is
already a multiple of 256, so 1280-wide frames came out byte-exact and hid the
bug; 640-wide frames tore, every row sliding 128 bytes with a green band at the
bottom. Take the stride from the image's stored plane offset so it matches the
real layout at any width.

Byte-exact at 360p, 720p and 1080p, cropped heights included, on an RK3588.

Signed-off-by: Saverio Pavone <pavone.lawyer@gmail.com>
Assisted-by: Claude:claude-opus-4-8
---
 src/vulkan-v4l2/v4l2vk_vk_device.c | 12 +++++++++++-
 1 file changed, 11 insertions(+), 1 deletion(-)

diff --git a/src/vulkan-v4l2/v4l2vk_vk_device.c b/src/vulkan-v4l2/v4l2vk_vk_device.c
index 90deae3..7c0d5df 100644
--- a/src/vulkan-v4l2/v4l2vk_vk_device.c
+++ b/src/vulkan-v4l2/v4l2vk_vk_device.c
@@ -247,7 +247,17 @@ v4l2vk_CmdCopyImageToBuffer2(VkCommandBuffer commandBuffer,
 
    const uint32_t img_width = image->ci.extent.width;
    const uint32_t img_height = image->ci.extent.height;
-   const uint32_t stride = v4l2vk_align_u32(img_width, 256u);
+   /* readback row stride MUST match the layout the frame was
+    * created and memcpy'd with (CreateImage NV12 + decode bulk copy use
+    * align16(width) = the V4L2 CAPTURE bytesperline).  Recover it from the
+    * stored plane-1 offset so it is correct for any width-alignment rule;
+    * the old align256(width) only matched at 256-multiple widths (1280) and
+    * drifted by (align256(w)-w) bytes/row otherwise (e.g. 768-640=128). */
+   const uint32_t h_aligned = v4l2vk_align_u32(img_height, 16u);
+   const uint32_t stride =
+      (image->plane_count > 1 && h_aligned)
+         ? (uint32_t)(image->planes[1].offset / h_aligned)
+         : v4l2vk_align_u32(img_width, 16u);
    const uint32_t uv_height = (img_height + 1u) / 2u;
    const uint64_t layer_size = (uint64_t)stride * (img_height + uv_height);
 
