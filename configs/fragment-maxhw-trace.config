# Rock5B+ beryllium-complete — delta over in-tree beryllium_rk3588_defconfig.
# (PHYs/PCIe/UFS/TYPEC etc. are ALREADY in the base defconfig — not repeated here.)
# AV1 IOMMU fix + build-safety + identity
CONFIG_VSI_IOMMU=y
CONFIG_MODULE_ALLOW_BTF_MISMATCH=y
CONFIG_LOCALVERSION="-beryllium"
# Tracing (traceble): ftrace infra activates V4L2 + hantro codec tracepoints
CONFIG_FTRACE=y
CONFIG_FUNCTION_TRACER=y
CONFIG_FUNCTION_GRAPH_TRACER=y
CONFIG_DYNAMIC_FTRACE=y
CONFIG_STACK_TRACER=y
CONFIG_FTRACE_SYSCALLS=y
CONFIG_TRACER_SNAPSHOT=y
CONFIG_BLK_DEV_IO_TRACE=y
# Extra RK3588 HW not in base defconfig
CONFIG_DRM_DW_HDMI_QP_CEC=y
CONFIG_PHY_ROCKCHIP_USBDP=m
CONFIG_SCSI_UFS_ROCKCHIP=y
CONFIG_ROCKCHIP_SARADC=m
CONFIG_SPI_ROCKCHIP_SFC=m
CONFIG_SND_SOC_ROCKCHIP_SAI=m
CONFIG_VIDEO_ROCKCHIP_CIF=m
CONFIG_DEVFREQ_EVENT_ROCKCHIP_DFI=m
CONFIG_CRYPTO_SM3=m
CONFIG_CRYPTO_SHA3=m
