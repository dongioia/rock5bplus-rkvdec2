+++ b/src/gallium/drivers/panfrost/pan_resource.c
@@ -450,7 +450,19 @@ panfrost_resource_get_handle(struct pipe_screen *pscreen,
                              struct winsys_handle *handle, unsigned usage)
 {
    struct panfrost_device *dev = pan_device(pscreen);
-   struct panfrost_resource *rsrc = pan_resource(pt);
+
+   /* For multi-plane YUV (NV12), walk the ->next chain to find the
+    * correct plane's resource. Each plane is a separate pipe_resource
+    * linked via ->next (Y plane -> UV plane). This mirrors the pattern
+    * used in panfrost_resource_get_param with util_resource_at_index. */
+   struct panfrost_resource *rsrc;
+   if (handle->plane > 0 && pt->next) {
+      rsrc = pan_resource(util_resource_at_index(pt, handle->plane));
+      handle->plane = 0;
+   } else {
+      rsrc = pan_resource(pt);
+   }
+
    struct renderonly_scanout *scanout;
 
    if (handle->plane >= ARRAY_SIZE(rsrc->image.planes) ||
@@ -1177,6 +1189,41 @@ static struct pipe_resource *
 panfrost_resource_create(struct pipe_screen *screen,
                          const struct pipe_resource *template)
 {
+   unsigned num_planes = util_format_get_num_planes(template->format);
+
+   /* Multi-plane YUV formats (e.g. NV12) need each plane allocated
+    * separately and linked via pipe_resource->next. This enables GBM
+    * allocation of YUV buffers for V4L2 video decode on ARM GPUs. */
+   if (num_planes > 1) {
+      struct pipe_resource *prev = NULL;
+
+      for (int i = num_planes - 1; i >= 0; i--) {
+         struct pipe_resource tmpl = *template;
+         tmpl.format = util_format_get_plane_format(template->format, i);
+         tmpl.width0 = util_format_get_plane_width(template->format, i,
+                                                    template->width0);
+         tmpl.height0 = util_format_get_plane_height(template->format, i,
+                                                      template->height0);
+         tmpl.next = prev;
+
+         struct pipe_resource *plane =
+            panfrost_resource_create_with_modifier(screen, &tmpl,
+                                                   DRM_FORMAT_MOD_LINEAR, i);
+         if (!plane) {
+            /* TODO: clean up previously allocated planes */
+            return NULL;
+         }
+
+         prev = plane;
+      }
+
+      /* prev is now the Y plane (i=0), with ->next pointing to UV plane.
+       * Set the top-level format to NV12 so the DRI layer knows this
+       * is a multi-plane YUV resource. */
+      prev->format = template->format;
+      return prev;
+   }
+
    return panfrost_resource_create_with_modifier(screen, template,
                                                  DRM_FORMAT_MOD_INVALID, 0);
 }
